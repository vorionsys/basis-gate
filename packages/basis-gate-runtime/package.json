{
  "name": "@vorionsys/basis-gate-runtime",
  "version": "0.1.1",
  "type": "module",
  "description": "Reference implementation of BASIS Gate v1. Resolves postures to pipelines, executes layers in block/inline/deferred modes, and produces a two-stage proof chain for every gated action.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./layers": {
      "types": "./dist/layers/index.d.ts",
      "import": "./dist/layers/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "keywords": [
    "basis",
    "ai-governance",
    "gate-runtime",
    "proof-chain",
    "vorion"
  ],
  "author": "Vorion LLC <team@vorion.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/vorionsys/basis-gate.git",
    "directory": "packages/basis-gate-runtime"
  },
  "dependencies": {
    "@vorionsys/basis-gate-spec": "^0.1.0",
    "@vorionsys/basis-gate-industry": "^0.1.1",
    "@noble/ed25519": "^2.0.0",
    "@noble/hashes": "^1.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "homepage": "https://github.com/vorionsys/basis-gate#readme",
  "bugs": {
    "url": "https://github.com/vorionsys/basis-gate/issues"
  }
}
